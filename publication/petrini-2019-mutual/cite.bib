@inproceedings{petrini2019mutual,
 abstract = {Interpretability is a major concern when applying deep convolutional neural
networks to image data. In this work we introduce a tool based on recent advances in
Mutual Information estimation that makes it possible to investigate which parts of an
image are important for the learned representations when trying to distinguish it from
another. This pairwise approach is evaluated on a set of supervised and unsupervised
representation learning models and leads to qualitative insights into the specificities
of each representation. In particular, we find that very different supervised learning
algorithms are able to recover semantic structure and that reconstruction-based
models such as VAEs are more sensitive to pixel similarity rather than semantic
proximity, which would most likely be detrimental to generalization.},
 author = {Linda Petrini and Tristan Sylvain and Devon Hjelm},
 booktitle = {Workshop on Information Theory and Machine Learning - NeurIPS},
 title = {Mutual Information heatmaps as a tool for interpretability},
 url = {https://drive.google.com/file/d/1dSv8b__YbGc-KXfVjTQB5yTUW57MyhYJ/view},
 year = {2019}
}

